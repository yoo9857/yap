# Robo Builder stream bridge — copy to .env and fill in what you use.
# Each source is optional; the bridge runs with any subset configured.

# Local WebSocket + webhook port the game connects to.
STREAM_BRIDGE_PORT=8083

# --- YouTube live chat + Super Chat (OAuth on YOUR broadcasting channel) ---
# Create an OAuth client (type "Desktop") in Google Cloud Console, enable the
# "YouTube Data API v3", then do the one-time consent to obtain a refresh token
# (scope: https://www.googleapis.com/auth/youtube.readonly). See README.
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
# Optional: pin a specific live video id. Leave blank to auto-find your active broadcast.
YT_VIDEO_ID=
# Chat lines starting with this fire a cheer boost. "" disables chat, "*" forwards every line.
YT_CHAT_TRIGGER=!build

# --- Toonation (투네이션) ---
# Your alert box URL from the Toonation dashboard.
TOONATION_ALERTBOX_URL=

# --- Twip (트윕) ---
# Your alert box URL from the Twip dashboard.
TWIP_ALERTBOX_URL=

# --- Generic webhook (optional) ---
# If set, POST /webhook must include header  x-bridge-secret: <this value>
WEBHOOK_SECRET=
