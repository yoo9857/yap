# CraftYap production env — copy to .env on the server and adjust.
# The container always serves on 8081 internally; these control the host side.

# Host port nginx proxies to (kept clear of poke's 3000).
HOST_PORT=8082

# SEPARATE SQLite database directory on the HOST (bind-mounted into the
# container at /app/apps/server/data). Managed independently of poke —
# back it up and wipe it on its own. Must be writable by the container user.
DB_DIR=/srv/craftyap/data

# ---- app config (read by apps/server/src/config.ts) ----
# SERVE_STATIC and PORT are baked into the image; override here only if needed.
# Daily-tower day boundary, minutes east of UTC. KST (+9h) = 540.
DAY_UTC_OFFSET_MIN=540
# trace | debug | info | warn | error
LOG_LEVEL=info
# Max players sharing one room on the daily seed.
MAX_PLAYERS_PER_ROOM=8
